# =============================================================================
# Homelab Dashboard – .env
# Kopiere nach .env und passe die Pflichtfelder an.
# =============================================================================

# --- Pflicht (Production) ---
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters

# --- Docker / Production ---
PORT=3333
# Hinter Reverse Proxy (HTTPS): öffentliche URL für Redirects nach Login
# APP_URL=https://dashboard.example.com
# COOKIE_SECURE=true

# --- Lokal (npm run dev) ---
# PORT=3000

# --- Optional (Standardwerte reichen fast immer) ---
# CREDENTIALS_ENCRYPTION_SECRET=   # Standard: SESSION_SECRET
# CREDENTIALS_ENCRYPTION_SALT=homelab-dashboard-salt
# SESSION_MAX_AGE_DAYS=7
# DATABASE_URL=file:./data/dashboard.db
