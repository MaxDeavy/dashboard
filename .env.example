# =============================================================================
# Homelab Dashboard – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# =============================================================================

# --- Auth & Verschlüsselung (Production: alle setzen!) ---
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters
# Optional: separates Secret für Widget-Zugangsdaten in der DB (Standard: SESSION_SECRET)
# CREDENTIALS_ENCRYPTION_SECRET=
# Salt für AES-Key-Ableitung (nur ändern, wenn du weißt was du tust)
CREDENTIALS_ENCRYPTION_SALT=homelab-dashboard-salt

# --- Session-Cookie ---
SESSION_COOKIE_NAME=homelab-dashboard-session
# true = Cookie nur über HTTPS (hinter TLS-Terminierung setzen)
COOKIE_SECURE=false

# --- Datenbank ---
DATABASE_URL=file:./data/dashboard.db

# --- Server ---
# Lokal (npm run dev):
PORT=3000
# Docker (docker compose) – Port im Container und Mapping müssen übereinstimmen:
# PORT=3333
HOSTNAME=0.0.0.0
NODE_ENV=development

# --- Client-Speicher (localStorage-Präfix im Browser) ---
APP_STORAGE_PREFIX=homelab-dashboard
NEXT_PUBLIC_APP_STORAGE_PREFIX=homelab-dashboard

# --- Upload-Limits (MB) ---
MAX_BACKGROUND_UPLOAD_MB=5
MAX_LOGO_UPLOAD_MB=1
MAX_ICON_UPLOAD_MB=1

# --- Docker-Beispiel (in .env für docker compose) ---
# PORT=3333
# DATABASE_URL=file:/app/data/dashboard.db
# NODE_ENV=production
# COOKIE_SECURE=false