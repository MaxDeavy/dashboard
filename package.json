{
  "name": "homelab-dashboard",
  "version": "1.0.3",
  "description": "Self-hosted homelab dashboard with browser-based configuration, health checks, and API hover widgets",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "npm run assets:sync && next dev",
    "build": "npm run assets:sync && next build",
    "assets:sync": "node -e \"const fs=require('fs');const p='public/assets';fs.mkdirSync(p,{recursive:true});if(fs.existsSync('assets')){for(const f of fs.readdirSync('assets')){fs.copyFileSync('assets/'+f,p+'/'+f);}}\"",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "hash-password": "tsx scripts/hash-password.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MaxDeavy/dashboard.git"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
